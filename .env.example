# ========================================
# DATABASE — Neon PostgreSQL
# ========================================
# Pooled connection (for runtime — with pgbouncer)
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1

# Direct connection (for Prisma migrations — no pgbouncer)
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DIRECT_URL=postgresql://neondb_owner:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ========================================
# AUTHENTICATION
# ========================================
# The URL where your application is running
BETTER_AUTH_URL=http://localhost:3000
# Generate a secure random string using: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here

# ========================================
# GOOGLE OAUTH
# ========================================
# Get these from Google Cloud Console: https://console.cloud.google.com
# Required scopes: email, profile
# Authorized redirect URIs: https://your-domain.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ========================================
# PUBLIC URL
# ========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================================
# ENVIRONMENT
# ========================================
NODE_ENV=development

# ========================================
# SMTP (Optional — for email verification & password reset)
# ========================================
# Recommended free providers: Resend (100/day), Brevo (300/day)
# Resend example: host=smtp.resend.com, port=465, user=resend, pass=re_xxx
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Workout Cool <noreply@yourdomain.com>"
SMTP_SECURE=false

# ========================================
# ANALYTICS (Optional)
# ========================================
OPENPANEL_SECRET_KEY=
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
